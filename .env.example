# Required
HOST_REPO_PATH=/absolute/path/to/your/repo
WAYLAND_SOCKET_PATH=/run/user/1000/wayland-0

# Optional overrides
COMPOSE_PROJECT_NAME=emacs-opencode-myrepo
CONTAINER_USER=dev
OPENCODE_NPM_PACKAGE=opencode-ai

# If unset, scripts/dev-up.sh auto-detects id -u / id -g
HOST_UID=1000
HOST_GID=1000

# Optional explicit workspace name in container; defaults to basename(HOST_REPO_PATH)
# WORKSPACE_DIRNAME=myrepo

# Optional host paths; defaults are set by scripts/dev-up.sh
# HOST_OPENCODE_DIR=~/.local/share/opencode
# HOST_EMACS_D_DIR=~/.emacs.d-container
# HOST_CACHE_DIR=~/.cache
# HOST_NPM_CACHE_DIR=~/.npm
# HOST_PNPM_STORE_DIR=~/.local/share/pnpm/store
# HOST_PNPM_HOME_DIR=~/.local/share/pnpm
# HOST_PIP_CACHE_DIR=~/.cache/pip
