COMPOSE_PROJECT_NAME=emacs-opencode
CONTAINER_USER=dev
# UID and GUID from user running the container, i.e., output of `id -u` and `id -g`
HOST_UID=1000
HOST_GID=1000
# path to the repo (probably where the .env file will be)
HOST_REPO_PATH=/absolute/path/to/your/host/checkout

# Mount your existing shared OpenCode data dir here (contains auth.json, db, snapshots, etc.).
HOST_OPENCODE_DIR=/home/your-user/.local/share/opencode

# Optional read-only secrets directory (can contain opencode.env, openai.env, etc.).
HOST_SECRETS_DIR=/home/your-user/.mysecrets/opencode

WAYLAND_DISPLAY=wayland-0
# the 1000 is the path below is userid
WAYLAND_SOCKET_PATH=/run/user/1000/wayland-0
TZ=UTC

# Moderate resource controls; adjust for your laptop.
CPU_LIMIT=4
MEM_LIMIT=8g
PIDS_LIMIT=512

# Optional override if your OpenCode package differs.
OPENCODE_NPM_PACKAGE=opencode-ai

WORKSPACE_VOLUME_NAME=emacs_opencode_workspace
EMACS_STATE_VOLUME_NAME=emacs_opencode_emacs_state
NPM_CACHE_VOLUME_NAME=emacs_opencode_npm_cache
PNPM_STORE_VOLUME_NAME=emacs_opencode_pnpm_store
PNPM_HOME_VOLUME_NAME=emacs_opencode_pnpm_home
PIP_CACHE_VOLUME_NAME=emacs_opencode_pip_cache
